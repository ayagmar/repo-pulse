{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "bun install",
      "group": "build"
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "bun run build",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "bun run test",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "bun run lint",
      "group": "build"
    },
    {
      "label": "Format",
      "type": "shell",
      "command": "bun run format",
      "group": "build"
    },
    {
      "label": "Type Check",
      "type": "shell",
      "command": "bun run typecheck",
      "group": "build"
    }
  ]
}
